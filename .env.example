# ── GitHub ────────────────────────────────────────────────────────────────────
# Token com permissão de leitura nos repos da org
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_ORG=YourOrg

# ── Jira / Atlassian ─────────────────────────────────────────────────────────
# Usado pelo MCP do Atlassian (.mcp.json) e pelo installer
# Crie um API token em: https://id.atlassian.com/manage/api-tokens
JIRA_URL=https://your-org.atlassian.net
JIRA_USERNAME=seu.email@your-org.com
JIRA_API_TOKEN=ATATTxxxxxxxxxxxxxxxxxx
CONFLUENCE_URL=https://your-org.atlassian.net/wiki

# ── Knowledge Service ─────────────────────────────────────────────────────────
# URL do serviço centralizado (compartilhado entre agentes do time)
KNOWLEDGE_SERVICE_URL=http://localhost:8080

# Identificador deste agente (usado para rastrear quem fez o quê)
AGENT_ID=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=knowledge
POSTGRES_USER=aieng
POSTGRES_PASSWORD=aieng
DATABASE_URL=postgres://aieng:aieng@localhost:5432/knowledge?sslmode=disable

# ── Embedder (escolha um, comente os demais) ──────────────────────────────────

# Google Gemini — gratuito (1.500 req/dia), recomendado como padrão
# Obtenha sua key em: https://aistudio.google.com/apikey
EMBEDDER_PROVIDER=gemini
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Ollama — gratuito, local, requer Docker
# EMBEDDER_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Voyage AI — 200M tokens grátis, melhor para código
# Obtenha sua key em: https://www.voyageai.com
# EMBEDDER_PROVIDER=voyage
# VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxx
# VOYAGE_EMBEDDING_MODEL=voyage-code-2

# OpenAI — pago, $0.02/MTok
# EMBEDDER_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Scan / Watch ──────────────────────────────────────────────────────────────
REPO_LIMIT=200
SINCE_HOURS=24
REPOS_DIR=~/git
STATE_FILE=~/.ai-engineer/.watch-state
OUTPUT_DIR=~/.ai-engineer/org-knowledge
